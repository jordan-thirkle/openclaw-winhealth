{
  "name": "@jordan-thirkle/openclaw-winhealth",
  "version": "1.6.0",
  "type": "module",
  "description": "OpenClaw Cross-Platform Health Monitor — diagnose and fix gateway issues. Background health polling, multi-channel alerts (WhatsApp/Telegram), event loop monitoring, and automated diagnostics. Works on Windows, Linux, and macOS.",
  "keywords": [
    "openclaw",
    "plugin",
    "health",
    "monitoring",
    "diagnostics",
    "cross-platform",
    "linux",
    "macos",
    "windows",
    "gateway",
    "performance",
    "security"
  ],
  "author": "Jordan Thirkle",
  "license": "MIT",
  "files": ["index.js", "tools/", "hooks/", "dashboard/", "openclaw.plugin.json", "LICENSE", "README.md", "SECURITY.md"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordan-thirkle/openclaw-winhealth.git"
  },
  "homepage": "https://github.com/jordan-thirkle/openclaw-winhealth#readme",
  "openclaw": {
    "extensions": ["./index.js"],
    "compat": {
      "pluginApi": ">=2026.5.0",
      "minGatewayVersion": "2026.5.0"
    },
    "build": {
      "openclawVersion": "2026.5.0",
      "pluginSdkVersion": "2026.5.0"
    }
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit:security": "npm audit",
    "publish:clawhub": "clawhub package publish jordan-thirkle/openclaw-winhealth",
    "publish:clawhub:dry": "clawhub package publish jordan-thirkle/openclaw-winhealth --dry-run"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
