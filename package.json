{
  "name": "@jordan-thirkle/openclaw-winhealth",
  "version": "1.0.0",
  "type": "module",
  "description": "OpenClaw Windows Health Monitor — diagnose and fix Windows-specific OpenClaw issues. Background health polling, WhatsApp alerts, event loop monitoring, Windows Task Scheduler checks, prewarm detection, and diagnostic bundle generation.",
  "keywords": [
    "openclaw",
    "plugin",
    "windows",
    "health",
    "monitoring",
    "diagnostics",
    "win32",
    "gateway",
    "performance"
  ],
  "author": "Jordan Thirkle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jordan-thirkle/openclaw-winhealth.git"
  },
  "homepage": "https://github.com/jordan-thirkle/openclaw-winhealth#readme",
  "openclaw": {
    "extensions": ["./index.ts"],
    "compat": {
      "minGatewayVersion": "2026.5.0"
    },
    "build": {
      "openclawVersion": "2026.5.0"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "test": "echo \"Manual test: openclaw plugins install . && openclaw plugins inspect winhealth --runtime\"",
    "publish:clawhub": "clawhub package publish jordan-thirkle/openclaw-winhealth",
    "publish:clawhub:dry": "clawhub package publish jordan-thirkle/openclaw-winhealth --dry-run"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.0"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
